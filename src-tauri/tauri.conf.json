{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "penguin-tools",
  "version": "2.0.0",
  "identifier": "com.foahh.penguintools",
  "build": {
    "beforeDevCommand": "bun run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "bun run stage:runtime && bun run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "PenguinTools",
        "width": 1100,
        "height": 750,
        "minWidth": 900,
        "minHeight": 600,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "nsis"
    ],
    "createUpdaterArtifacts": true,
    "resources": {
      "resources/runtime/": "runtime/"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "skip"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEIxQjA5OEZBQTc3QzVEQTgKUldTb1hYeW4rcGl3c2JaNmliNWc0TjVucVY0ZEVxaHlXTGhjbFR4SUsrY2Y0RkJVYTYzMGVjVjMK",
      "endpoints": [
        "https://releases.foahh.com/penguin-tools/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
